// vim: set tabstop=4,shiftwidth=4,expandtabs,ft=conf
// {{ template_destpath }}

{% for key in bind_tsig_keys %}
include "{{ __bind_conf_dir }}/{{ key.name }}.key";
{% endfor %}
{% if bind_tsig_keys %}

{% endif %}
{% if __bind_main_config_style == "include" %}
{% for include in __bind_main_includes %}
include "{{ include }}";
{% endfor %}
{% else %}
{% for acl in bind_acls %}
acl "{{ acl.name }}" {
{% for entry in acl.entries %}
    {{ entry }};
{% endfor %}
};

{% endfor %}
{% for primaries in bind_primaries %}
primaries "{{ primaries.name }}" {
{% for entry in primaries.entries %}
    {{ entry }};
{% endfor %}
};

{% endfor %}
{% if bind_controls %}
controls {
{% for control in bind_controls %}
    {{ control }};
{% endfor %}
};

{% endif %}
options {
{% for option in __bind_options + __bind_platform_options + bind_options %}
{% if option.include is defined and option.include %}
    include "{{ option.include }}";
{% elif option.raw is defined %}
{% if option.raw is string %}
{% for line in option.raw.splitlines() %}
    {{ line }}
{% endfor %}
{% else %}
{% for line in option.raw %}
    {{ line }}
{% endfor %}
{% endif %}
{% elif option.entries is defined %}
    {{ option.name }}{% if option.arguments is defined %} {{ option.arguments }}{% endif %} {
{% for entry in option.entries %}
        {{ entry }};
{% endfor %}
    };
{% elif option.value is defined %}
{% if option.value is not none and option.value | string | length > 0 %}
{% if option.quote is defined and option.quote %}
    {{ option.name }} "{{ option.value }}";
{% else %}
    {{ option.name }} {{ option.value }};
{% endif %}
{% endif %}
{% endif %}
{% endfor %}
};

{% if bind_logging.channels or bind_logging.categories %}
logging {
{% for channel in bind_logging.channels %}
    channel {{ channel.name }} {
{% if channel.file is defined %}
        file "{{ channel.file }}"{% if channel.file_options is defined %} {{ channel.file_options }}{% endif %};
{% endif %}
{% if channel.severity is defined %}
        severity {{ channel.severity }};
{% endif %}
{% if channel.print_time is defined %}
        print-time {{ 'yes' if channel.print_time else 'no' }};
{% endif %}
{% if channel.print_severity is defined %}
        print-severity {{ 'yes' if channel.print_severity else 'no' }};
{% endif %}
{% if channel.print_category is defined %}
        print-category {{ 'yes' if channel.print_category else 'no' }};
{% endif %}
    };
{% endfor %}
{% for category in bind_logging.categories %}
    category {{ category.name }} { {% for channel in category.channels %}{{ channel }}; {% endfor %}};
{% endfor %}
};

{% endif %}
{% for zone in __bind_platform_zones %}
{% if zone.comment is defined %}
// {{ zone.comment }}
{% endif %}
zone "{{ zone.name }}"{% if zone.class is defined %} {{ zone.class }}{% endif %} {
{% if zone.type is defined %}
    type {{ zone.type }};
{% endif %}
{% if zone.primaries is defined %}
    primaries { {% for entry in zone.primaries %}{{ entry }}; {% endfor %}};
{% endif %}
{% if zone.file is defined %}
    file "{{ zone.file }}";
{% endif %}
{% if zone.allow_update_forwarding is defined %}
    allow-update-forwarding { {% for entry in zone.allow_update_forwarding %}{{ entry }}; {% endfor %}};
{% endif %}
{% if zone.forward is defined %}
    forward {{ zone.forward }};
{% endif %}
{% if zone.forwarders is defined %}
    forwarders { {% for entry in zone.forwarders %}{{ entry }}; {% endfor %}};
{% endif %}
{% if zone.statements is defined %}
{% for statement in zone.statements %}
    {{ statement }};
{% endfor %}
{% endif %}
};

{% endfor %}
{% for include in __bind_includes %}
include "{{ include }}";
{% endfor %}
include "{{ __bind_local_file }}";

{% endif %}
